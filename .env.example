# --- LLM / AI providers ---
ANTHROPIC_API_KEY=your-anthropic-api-key
GROQ_API_KEY=your-groq-api-key
TAVILY_API_KEY=your-tavily-api-key

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
# Runtime Postgres DSN. For Supabase, prefer the SESSION pooler (port 5432) over the
# TRANSACTION pooler (port 6543): the transaction pooler can't run SQLAlchemy/alembic
# prepared statements and shows inconsistent read-after-write. If a 6543 URL is given,
# the app auto-routes it to 5432.
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:5432/skilllens
# Optional dedicated DSN for alembic migrations (direct/session connection, port 5432).
# Leave unset to reuse SUPABASE_DB_URL (session-pooler-routed). Example:
# SUPABASE_DB_DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key

# --- LangSmith / LangChain tracing ---
LANGCHAIN_API_KEY=your-langchain-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=skilllens
